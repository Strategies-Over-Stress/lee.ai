{
  "productName": "Pilot",
  "version": "0.1.0",
  "identifier": "ai.lee.pilot",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "windows": [
      {
        "title": "Pilot",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "icon": ["icons/icon.png"]
  }
}
